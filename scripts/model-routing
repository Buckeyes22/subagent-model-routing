#!/usr/bin/env python3
"""Repository-resolving entrypoint for the shared model-routing runtime."""

from __future__ import annotations

from pathlib import Path
import sys


ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT / "runtime"))

if sys.version_info < (3, 11):
    print("model-routing requires Python 3.11 or newer", file=sys.stderr)
    if len(sys.argv) > 1 and sys.argv[1] == "_shim":
        print("SHIM-DONE exit=127")
    raise SystemExit(127)

from model_routing.cli import main  # noqa: E402


if __name__ == "__main__":
    raise SystemExit(main())
